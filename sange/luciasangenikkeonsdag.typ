#import "//template.typ": *

#sang("F-Klubbens Lucia Sang", subtext: "Foret, 2023 - Mel: Sankta Lucia", cols: 2)[
  #vers[
    Nu er det juletid, \
    Det skal jo fejres: \
    Da bringes øllen hid, \
    Drik noget bajer. \
    F-klubbens julefred \
    Gør hver en fember glad \
    Cassiopeia, Cassiopeia
  ]

  #csplit

  #vers[
    Her ved vor fønskefest, \
    sangen skal kime, \
    monner til hver en gæst, \
    liv vil vi bringe. \
    Skænk os af lykkens fad, \
    Li’ til nog’t fjulemad \
    Cassiopeia, Cassiopeia
  ]
]
