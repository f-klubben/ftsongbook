#import "//template.typ": *

#sang("F-nüt 1985 - Rosset: Hold 1", subtext: "1985 - Mel: ?", cols: 2)[
  #vers[
    Vi går til daglig og integrerer \
    vi differentierer og substrabherer. \
    Men når til fredag vi holder fri \
    vi går til F-klubben \
    det ka vi li'.
  ]
  
  #note[#small[Fra sangkonkurrence i F-nüt 1985 1. årgang nr. 2.]]
  
  #csplit

  #vers[
    Vi spiller ludo og drikker bajere \
    Vi ta'r til Egholm som vi jo plejer \
    og her i aften med højt humør \
    vi vores røster vil lade høre.
  ]
]