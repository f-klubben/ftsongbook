#import "//template.typ": *

#set super(size: 7pt)

#sang("Veteranens nostalgiske sang", subtext: "Oprindelig af Finn Verner Jensen (FVJ) - Mel: I den gamle pavillon", cols: 2)[
  #vers[
    Jeg er cand.scient. fra Aalborg UC  \
    og jeg ska' nu til  \
    at prøv' at brug' det  \
    Ved 'Christian Rovsing'#super[†] er jeg blevet ansat#super[‡]  \
    Min frihed pantsat#super[§]  \
    i Ballerup#super[¶]  \
    Men når jeg er her i mit gamle hus  \
    vejrer jeg jo fordums sus  \
    Jeg drømmer mig tilbage til det gamle institut  \
    til de kurser som vi nød  \
    til lærerpræk ved tavlen hvor vi talte hvert minut,#super[‖]  \
    kaffestuens fredagsbrød  \
    En pause kunne strækkes meget længe,  \
    for kaf'maskin' var ganske uden fut  \
    Jo, vi forstod i kaffestuen at hænge  \
    på det gamle institut
  ]
  #v(-.25em)
  #note[#small[
    † I tidligere udgaver var det "Brønderslev". \
    ‡ Tidligere: "landsat". \
    § Tidligere: "måske ansat". \
    ¶ Tidligere: "Harboør". \
    ‖ Tidligere: "lærersnak som jo aldrig Kunne slutt'". \
  ]]

  #csplit

  #vers[
    Tænker på de fine F-klub-fester  \
    Ludo-kontester  \
    \- nu er vi gæster  \
    Når jeg kommer her er jeg en fremmed,  \
    har jeg fornemmet,  \
    det er lidt hårdt  \
    For det er jo her at mit hjerte slår  \
    gennem mange skønne år  \
    Jeg drømmer mig tilbage til det gamle institut  \
    Grupperummet hvor vi sad  \
    Med pæne diskussioner uden gnist og uden krudt#super[⁕]  \
    Kors i røven hvor vi gad#super[⁑]  \
    Men samfundet er fuldt af direktioner #super[⁂]   \
    der sørger for at freden den bli'r brudt  \
    mens der var rare mænd og ditto koner #super[※]   \
    på det gamle institut
  ]
  #v(-.25em)
  #note[#small[
    ⁕ Tidligere: "og drak af klubbens kasser, mens vi  gumled' en cerut". \
    ⁑ Tidligere: "snakked' lidt om hvem ved hvad". \
    ⁂ Tidligere: "I Brønderslev er fuldt af amazoner". \
    ※ Tidligere "rare koner". #super[⁜] \
    ⁜ Tidligere "ingen koner".
  ]]
]

