#import "//template.typ": *

#sang("F-nüt 1985 - Rosset: Hold 2", subtext: "1985 - Mel: Det var en lørdag aften", cols: 2)[
  #note[RIS TIL EGEN...]
  
  #vers[
    Vi sidder her ved bordet \
    og laver os en sang \
    og nu da vi har ordet \
    vi synger den en gang \
    ||: og sangen handler mestendels \
    om øl og F-klub-sjov :||
  ]

  #vers[
    Maden fra Mao's Kina \
    i hvertfald Vesterbro \
    og den ku' ikke bli' finere \
    den er i hvertfald go' \
    ||: der var så mange løse ris \
    vi næsten ej ku' spis' :||
  ]
  
  #note[#small[Fra sangkonkurrence i F-nüt 1985 1. årgang nr. 2]]
  
  #csplit

  #vers[
    Og her til slut vi glasset \
    vil hæve højt i flok \
    og DU, der ej tør' gør' det \
    du har vist fået nok \
    ||: og nu vi skåle vil engang \
    som slutning på vor sang :||
  ]

  #vers[
    Et ekstranummer får i \
    for vores sang er go' \
    og det må være rimelig \
    at vi en øl må få \
    ||: en præmie vi fortjent har \
    den sag er ganske klar :||
  ]
]