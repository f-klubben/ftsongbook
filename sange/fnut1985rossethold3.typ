#import "//template.typ": *

#sang("F-nüt 1985 - Rosset: Hold 3", subtext: "1985 - Mel: ?", cols: 2)[
  #vers[
    Vi her tilsammen er i kvæld \
    for Chineese food at æde \
    da samgen den er noget fæl \
    om dette ej vi kvæde.
  ]
  
  #note[#small[Fra sangkonkurrence i F-nüt 1985 1. årgang nr. 2. \
  Det postuleres dengang, om det var fortsættelsen til Hold 1's sang.]
  ]
  
  #csplit

  #vers[
    Men Finn han er en hærlig gut \
    en bajer har han ej givet \
    så skønt jeg ej er nogen eut \
    en (?) til vil være livet.
  ]
]