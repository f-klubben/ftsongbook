#import "//template.typ": *

#sang("F-Klubbens Lucia Sang (den franske version)", subtext: "Mel: Sankta Lucia", cols: 2)[
  #vers[
    Nu er det juletid, \
    Det skal jo fejres: \
    Da bringes øllen hid, \
    Drik noget bajer. \
    F-klubbens julefred \
    Gør hver en fember glad \
    Cassiopeia, Cassiopeia
  ]

  #vers[
    Her ved vor fønskefest, \
    sangen skal kime, \
    monner til hver en gæst, \
    liv vil vi bringe. \
    Skænk os af lykkens fad, \
    Li’ til en franskbrødsmad \
    Cassiopeia, Cassiopeia
  ]
]
