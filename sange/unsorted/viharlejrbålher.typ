#import "//template.typ": *

#sang("Vi har lejrbål her", subtext: "", cols: 2)[
  #vers[
    Vi har lejrbål her \
    mellem stammer og træer \
    på den lille ø \
    i den blanke sø.
  ]

  #vers[
    Det er Mexicos land \
    og en modig mand \
    han ka´ klare sig der \
    med et godt gevær.
  ]

  #vers[
    Men på Danger Hill \
    venter Sorte Bill \
    Ved et røveri \
    har han myrdet ti.
  ]

  #vers[
    Vor sherif er død \
    Det var Bill, der skød, \
    og hvor blodet flød, \
    dér blev jorden rød.
  ]

  #vers[
    Vi har fanget Bill \
    ham fra Danger Hill \
    og hans usle krop \
    den skal klynges op.
  ]

  #vers[
    Så nu ka vi bo \
    her i fred og ro \
    på den lille ø \
    i den blanke sø.
  ]
]