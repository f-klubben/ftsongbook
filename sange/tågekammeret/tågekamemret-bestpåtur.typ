#import "//template.typ": *

#sang("BEST på tur", subtext: [$bb(C)$ERM, 2025 - Mel: Oles nye autobil], cols: 2)[
  #vers[
    TK BEST på tur i bil \
    De ankommer med et smil \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]

  #vers[
    Øl i Jægerstuen, flot \
    BEST synes det lyder godt \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]

  #vers[
    Derfor til jer nu de si’r \
    At de kommer klokken fir’ \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]

  #vers[
    Men før de kan komme frem \
    Må de vid’, hvor bor Kresten? \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]

  #note[
    #small[TÅGEKAMMERET var på besøg til Feaster i 2025. De skulle sove i den daværende næstformands, Krestens, lejlighed]
  ]

  #csplit

  #vers[
    Mon de kan parkere der \
    Med en bil og så en mer? \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]

  #vers[
    Liggeunderlag de har \
    Tre de tar med hjemmefra \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]

  #vers[
    Hvornår mon de skal ta’ hjem \
    Hvad mon synes ham Kresten? \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]

  #vers[
    Nu kan jeg ik find’ på mer \
    Sangen derfor slutter her \
    Trut - trut - trut - trut - trut \
    Trut - trut - trut - trut - trut
  ]
]