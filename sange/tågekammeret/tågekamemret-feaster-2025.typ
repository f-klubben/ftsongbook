#import "//template.typ": *

#sang("TÅGEKAMMERET på besøg", subtext: "CERM, 2025 - Mel: Til julebal i Nisseland ")[
  #vers[
    Det er blevet fredag nu, lige hvad, vi sku' brug' \
    Aftenen den blir suver fed, for nu går det ned
  ]

  #omkvæd[_
    TIl Påskefest, til påskefest med F-klubben \
    Der er madder, og øl ad libitum \
    Men hva' nu det? Der gæster fra et fremmed sted \
    #smallcaps[TÅGEKAMMERET]s bestyrelse er med \
    Og de har glæd't sig meget, og været langt på vej \
    Hvis du spørg' dem så tror jeg de vil bund' med dig \
    Til påskefest, til påske-påske-påske-påske-påskefest \
    Der er Feaster, i Cassipoeias hal
    _
  ]

  #vers[
    De er kommet 6 i alt, 2 derhjem', 8 totalt. \
    De vil nu fortælle jer, hvem monstro de er?
  ]

  #omkvæd[_
  Vi' TK-BEST, og ledet af vor FORM \
  $bb(C)$ERM han larmer, og skriver mangt en sang \
  V$bb(C)$ er her, hans øltrang den er enorm \
  Til en tuba, KAS\$\$ siger nej hver gang \
  Plakater laver PR, og de altid sej' \
  Hvis du ik' betaler til INKA tæve dig \
  Og vores NF hun spammer løbesedker overalt hun går \
  SEKR skriver, alt det som vi fomår
  _
  ]

  #vers[
    Denne sang har været lang, og vi skal, snart i gang \
    Men vi har et omkvæd mer- hør det kommer her
  ]

  #omkvæd[_
    Nu er det fest, det glæder os at være gæst- \
    er, for vi er, blev't taget godt imod \
    Og vi har rejst, igennem slud og regn og blæst \
    #smallcaps[TÅGEKAMMERET] i morges vi forlod \
    Nu skal vi drikke bajer, og fnaps og synge sang' \
    Vi håber, og tror på, at aftenen den bli'r lang \
    For nu er vi til påske-påske-påske-påske-påskefest \
    Der er Feaster, i Cassipoeias hal
    _
  ]

  #note[
    #small[TÅGEKAMMERET var på besøg til Feaster i 2025]
  ]
]